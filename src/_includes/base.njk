<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="alternate" type="application/atom+xml" title="{{ site.title }}" href="{{ '/feed.xml' | url }}">
    <style>
      :root {
        --bg: #ffffff;
        --fg: #1a1a1a;
        --muted: #6b6b6b;
        --accent: #2b6cb0;
        --rule: #e5e5e5;
        --code-bg: #f4f4f5;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #111315;
          --fg: #e8e8e8;
          --muted: #9aa0a6;
          --accent: #7ab7ff;
          --rule: #2a2d31;
          --code-bg: #1c1f22;
        }
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        font-size: 17px;
        line-height: 1.65;
        color: var(--fg);
        background: var(--bg);
      }
      .wrap { max-width: 720px; margin: 0 auto; padding: 2rem 1.25rem 4rem; }
      a { color: var(--accent); }
      a:hover { text-decoration: none; }
      header.site { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
      header.site .title { font-weight: 700; font-size: 1.1rem; text-decoration: none; color: var(--fg); }
      header.site nav a { margin-left: 1rem; color: var(--muted); text-decoration: none; }
      header.site nav a:hover { color: var(--fg); }
      h1, h2, h3 { line-height: 1.25; }
      h1 { font-size: 1.9rem; margin: 0 0 .25rem; }
      h2 { font-size: 1.35rem; margin-top: 2.5rem; }
      hr { border: 0; border-top: 1px solid var(--rule); margin: 2rem 0; }
      img { max-width: 100%; height: auto; }
      pre, code { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: .92em; }
      pre { background: var(--code-bg); padding: 1rem; border-radius: 6px; overflow-x: auto; }
      code { background: var(--code-bg); padding: .1em .35em; border-radius: 4px; }
      pre code { background: none; padding: 0; }
      blockquote { margin: 1.5rem 0; padding: .25rem 1rem; border-left: 3px solid var(--rule); color: var(--muted); }
      .post-meta { color: var(--muted); font-size: .92rem; margin-bottom: 2rem; }
      .post-list { list-style: none; padding: 0; }
      .post-list li { margin: 1.5rem 0; padding-bottom: 1.5rem; border-bottom: 1px solid var(--rule); }
      .post-list li:last-child { border-bottom: 0; }
      .post-list h2 { margin: 0 0 .25rem; font-size: 1.2rem; }
      .post-list h2 a { color: var(--fg); text-decoration: none; }
      .post-list h2 a:hover { color: var(--accent); }
      .post-list time { color: var(--muted); font-size: .9rem; }
      footer.site { margin-top: 4rem; padding-top: 1.5rem; border-top: 1px solid var(--rule); color: var(--muted); font-size: .9rem; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <a href="{{ '/' | url }}" class="title">{{ site.title }}</a>
        <nav>
          <a href="{{ '/' | url }}">Home</a>
          <a href="{{ '/about/' | url }}">About</a>
          <a href="{{ '/feed.xml' | url }}">Feed</a>
        </nav>
      </header>
      <main>
        {{ content | safe }}
      </main>
      <footer class="site">
        © {{ year }}{% if site.author %} {{ site.author }}{% endif %} ·
        Built with <a href="https://www.11ty.dev/">Eleventy</a>.
      </footer>
    </div>
  </body>
</html>
