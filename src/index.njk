---
layout: base.njk
title: Home
---
<h1>{{ site.title }}</h1>
<p>{{ site.description }}</p>

<h2>Posts</h2>
{% if collections.posts and collections.posts.length %}
  <ul class="post-list">
    {% for post in collections.posts %}
      <li>
        <h2><a href="{{ post.url | url }}">{{ post.data.title }}</a></h2>
        <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        {% if post.data.description %}
          <p>{{ post.data.description }}</p>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
{% else %}
  <p>No posts yet.</p>
{% endif %}
